# Copy to .env.deploy (gitignored) and fill in. Do NOT commit .env.deploy.
#
# Strato VPS deploy target for aiact.annotated.nl

# Hostname or IP of the Strato VPS
VPS_HOST=

# SSH user that owns VPS_PATH on the VPS
VPS_USER=

# Absolute path on the VPS where the site should land.
# Matches the `root` directive in your Caddyfile block for aiact.annotated.nl.
# Example: /var/www/aiact.annotated.nl
VPS_PATH=

# Optional: SSH port (default 22)
SSH_PORT=22

# Optional: path to SSH private key. Omit to use ssh-agent or default key.
# SSH_KEY=~/.ssh/id_ed25519_strato
