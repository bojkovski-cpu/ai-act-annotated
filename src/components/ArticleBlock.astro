---
/**
 * ArticleBlock — per-article render with tabs (Recitals / Drafting History
 * / AI Omnibus / Case Law / Guidance).
 *
 * Step 4.3b: takes a `lang` prop and consumes the loader. Internal links
 * are locale-prefixed. House principle: AI Act class names + JSX
 * structure preserved verbatim from the pre-i18n version.
 *
 * Omnibus on /nl/: EN body + Dutch chrome tag ("Bron: COM(2025) 836 —
 * beschikbaar in het Engels") per the 4.3b decision recorded with Pavle.
 * UI chrome strings (tab labels) stay English on both locales.
 *
 * Step 5.3 (2026-04-28): the Guidance tab is wired to real data from
 * `getGuidanceCitationsForArticle`. The tab and panel are both hidden when
 * the article has zero citations in the current language — same convention
 * as the Recitals / History / Omnibus tabs. Cards aggregate by
 * (guidance_id, language); multiple pin-cites within the same article
 * collapse into a single card with the pin-cites listed inside it. Sort:
 * adoption_date desc, canonical_id asc tie-break (deterministic for
 * byte-identical re-builds). Decision 4-D (Brontaal: source language
 * label) is delegated to GuidanceCard's title fallback. The i18n metadata
 * silent-fallback case (multi-lang doc, target title not yet ingested)
 * lives in `getGuidanceTitleFor` and is also surfaced via the same card.
 * The two cases differ in whether the doc has the page language in
 * `doc.languages`; comments at the call site describe the distinction.
 */
import {
  getRelatedRecitals,
  getOmnibusAmendmentsForArticle,
  getDraftingSnapshotsForArticle,
  getDraftingHistoryGaps,
  getDraftingStages,
  getGuidanceCitationsForArticle,
  getGuidanceDoc,
  getInternalReferencesFor,
  getExternalReferencesFor,
  getArticlesReferencing,
  getChapterForArticle,
} from '@/lib/loader';
import { wrapReferences } from '@/lib/references';
import type { Article, GuidanceCitation, GuidanceDoc, Lang } from '@/types/aiact';
import DraftingHistory from '@/components/DraftingHistory.astro';
import GuidanceCard from '@/components/GuidanceCard.astro';

interface Props {
  article: Article;
  lang: Lang;
}

const { article, lang } = Astro.props;

// Resolve related recitals — language-resolved via loader.
const relatedRecitals = getRelatedRecitals(article.number, lang).map((rec) => ({
  number: rec.number,
  text: rec.text,
  href: '/' + lang + '/recitals/recital-' + rec.number + '/',
}));

// Drafting history — bilingual via loader (4.4). Snapshots in this article's
// language at every stage that covers it; gaps surface where the alternate
// language has coverage but this one does not (Decision 3, bidirectional).
const draftingSnapshots = getDraftingSnapshotsForArticle(article.number, lang);
const draftingGaps = getDraftingHistoryGaps(article.number, 'articles');
const draftingStages = getDraftingStages(lang);

// Omnibus amendments — EN data; on /nl/ render with NL chrome tag.
const omnibusAmendments = getOmnibusAmendmentsForArticle(article.number);

// Guidance — 5.3: aggregate per (guidance_id, language) and sort by
// adoption_date desc with canonical_id tie-break.
//
// The loader's `getGuidanceCitationsForArticle(articleNumber, lang)` already
// filters to the current language. This means the (guidance_id, language)
// aggregation key is effectively (guidance_id) per page render. The language
// is kept in the key for defensive symmetry against a future loader change
// that returns mixed-language entries (e.g. "show fallback" semantics).
type PinCiteEntry = {
  pin_cite: GuidanceCitation['pin_cite'];
  location_in_doc: GuidanceCitation['location_in_doc'];
};
type GuidanceCardData = {
  doc: GuidanceDoc;
  pinCites: PinCiteEntry[];
};

const guidanceCitations = getGuidanceCitationsForArticle(article.number, lang);
const guidanceAggregated = new Map<string, GuidanceCardData>();
for (const cit of guidanceCitations) {
  const key = `${cit.guidance_id}::${cit.language}`;
  let entry = guidanceAggregated.get(key);
  if (!entry) {
    const doc = getGuidanceDoc(cit.guidance_id);
    if (!doc) {
      // Dangling citation — should be impossible after 4.6's verifier ran.
      // Skip silently so the rest of the page still renders. 5.4's reverse-
      // link audit will pick this up if it does happen.
      continue;
    }
    entry = { doc, pinCites: [] };
    guidanceAggregated.set(key, entry);
  }
  entry.pinCites.push({
    pin_cite: cit.pin_cite,
    location_in_doc: cit.location_in_doc,
  });
}

// Decision 4 fallback semantics — applied at the card level inside
// GuidanceCard via `getGuidanceTitleFor`:
//   - Decision 4-D (single-language source, e.g. an EN-only doc on /nl/):
//     `doc.languages` does NOT include current `lang`. Title resolves to the
//     other language and the card renders an explicit "Brontaal: …" /
//     "Source language: …" label. The aggregated tab itself only contains
//     this case if a future loader change starts surfacing other-language
//     citations on the matching page; today it cannot, because the loader
//     filters citations to current language.
//   - i18n Decision 3 metadata rule (multi-lang doc, current-lang title not
//     yet ingested): `doc.languages` DOES include current `lang`, but
//     `doc.title[lang]` is null. `getGuidanceTitleFor` silently falls back
//     to EN — no label. The 5.2 EZ guide carries both titles so this branch
//     never fires for the current corpus; first single-lang doc in 5.6+
//     exercises Decision 4-D, and an asymmetric ingestion gap exercises the
//     silent-fallback path.
//
// Both branches resolve through the same component property, but the two
// cases are conceptually distinct — keep this comment if the rendering
// diverges.
const guidanceCards: GuidanceCardData[] = Array.from(guidanceAggregated.values()).sort((a, b) => {
  const da = (a.doc.adoption_date ?? '').replace(/-/g, '');
  const db = (b.doc.adoption_date ?? '').replace(/-/g, '');
  if (da !== db) return db.localeCompare(da);
  return (a.doc.canonical_id ?? '').localeCompare(b.doc.canonical_id ?? '');
});

// Article references (4.9b). The structured indexes are language-agnostic;
// the URL composition for external EUR-Lex links is language-aware via the
// LANG querystring parameter inside `wrapReferences`. Internal Astro routes
// pick up the current `lang` directly. Empty arrays are fine — the wrapper
// returns the original text untouched when there's nothing to annotate.
const internalRefs = getInternalReferencesFor(article.number, lang);
const externalRefs = getExternalReferencesFor(article.number, lang);
const referencedBy = getArticlesReferencing(article.number, lang);

// Pre-compute hrefs for the Referenced-by block — getChapterForArticle
// returns null only for unknown numbers; the parser's reverse index only
// names valid source articles, so the null branch is defensive.
const referencedByEntries = referencedBy.map((r) => {
  const ch = getChapterForArticle(r.source_article);
  const href = ch === null
    ? '#'
    : `/${lang}/articles/chapter-${ch}/article-${r.source_article}/`;
  // Build the pin-cite suffix only when the source paragraph is known.
  let pin = '';
  if (r.paragraph) {
    pin = `(${r.paragraph})`;
    if (r.letter) pin += `(${r.letter})`;
  }
  return {
    source_article: r.source_article,
    href,
    pin,
  };
});

const recitalCount = relatedRecitals.length;
// Tab count: stages where THIS language has a snapshot, plus stages where
// THIS language has a Decision-3 gap disclosure (so the user is told something
// at every stage where it's relevant). Final-2024 always exists (live
// regulation) so we add 1.
const historyStageCardCount = draftingStages.filter((stage) => {
  const hasSnap = draftingSnapshots.some((s) => s.stage === stage.id);
  const hasGap = draftingGaps.some((g) => g.stage === stage.id && g.missing_in === lang);
  return hasSnap || hasGap;
}).length;
const historyCount = historyStageCardCount + 1; // +1 for final-2024 card
const omnibusCount = omnibusAmendments.length;
const guidanceCount = guidanceCards.length;

const articleHref = '/' + lang + '/articles/chapter-' + article.chapter + '/article-' + article.number + '/';

function parseSubPoints(text: string) {
  const parts: { marker?: string; text: string }[] = [];
  const lines = text.split('\n');
  let currentText = '';
  let currentMarker: string | undefined;

  for (const line of lines) {
    const subMatch = line.match(/^\(([a-z])\)\s*/);
    if (subMatch) {
      if (currentText.trim()) {
        parts.push({ marker: currentMarker, text: currentText.trim() });
      }
      currentMarker = `(${subMatch[1]})`;
      currentText = line.replace(/^\([a-z]\)\s*/, '');
    } else {
      currentText += (currentText ? '\n' : '') + line;
    }
  }
  if (currentText.trim()) {
    parts.push({ marker: currentMarker, text: currentText.trim() });
  }
  return parts;
}

---

<div class="article-block" id={`article-${article.number}`}>
  <div class="article-header">
    <div>
      <span class="article-id">Article {article.number}</span>
      <span class="article-title-text">{article.title}</span>
    </div>
    <div class="article-badges">
      <div class="article-tools">
        <a class="article-tool-btn" href={articleHref} title="Permalink to Article">&#x1f517;</a>
      </div>
    </div>
  </div>

  <div class="article-body">
    {article.paragraphs.map((para: any) => {
      const parts = parseSubPoints(para.text);
      const hasNumber = para.number && para.number !== '0';

      // Wrap recognised reference patterns in <a> tags. The wrapper does
      // its own substring search per chunk — see lib/references.ts.
      const annotated = parts.map((part) => ({
        ...part,
        html: wrapReferences(part.text, internalRefs, externalRefs, lang).replace(/\n/g, '<br/>'),
      }));

      return (
        <div class="para-row">
          {hasNumber && <div class="para-num">{para.number}.</div>}
          <div class={`para-text${!hasNumber ? ' para-text-full' : ''}`}>
            {annotated.map((part, i) => (
              part.marker ? (
                <div class="sub-para">
                  <div class="sub-para-marker">{part.marker}</div>
                  <div set:html={part.html} />
                </div>
              ) : (
                <span set:html={part.html} />
              )
            ))}
          </div>
        </div>
      );
    })}
  </div>

  {(recitalCount > 0 || historyCount > 0 || omnibusCount > 0 || guidanceCount > 0) && (
    <div class="article-tabs" data-article={String(article.number)}>
      {recitalCount > 0 && (
        <div class="article-tab" data-tab="recitals" onclick="switchTab(this)">
          Recitals <span class="tab-count">{recitalCount}</span> <span class="tab-chevron">&#x25be;</span>
        </div>
      )}
      {historyCount > 0 && (
        <div class="article-tab" data-tab="history" onclick="switchTab(this)">
          Drafting History <span class="tab-count">{historyCount}</span> <span class="tab-chevron">&#x25be;</span>
        </div>
      )}
      {omnibusCount > 0 && (
        <div class="article-tab" data-tab="omnibus" onclick="switchTab(this)">
          AI Omnibus <span class="tab-count">{omnibusCount}</span> <span class="tab-chevron">&#x25be;</span>
        </div>
      )}
      <div class="article-tab" data-tab="caselaw" onclick="switchTab(this)">
        Case Law <span class="tab-count">0</span> <span class="tab-chevron">&#x25be;</span>
      </div>
      {guidanceCount > 0 && (
        <div class="article-tab" data-tab="guidance" onclick="switchTab(this)">
          Guidance <span class="tab-count">{guidanceCount}</span> <span class="tab-chevron">&#x25be;</span>
        </div>
      )}
    </div>
  )}

  {recitalCount > 0 && (
    <div class="tab-panel" data-panel="recitals" data-article={String(article.number)}>
      {relatedRecitals.map((rec) => (
        <div class="recital-card">
          <div class="recital-card-header">
            <a href={rec.href}>Recital {rec.number}</a>
          </div>
          <p>{rec.text.length > 300 ? rec.text.substring(0, 300) + '…' : rec.text}</p>
        </div>
      ))}
    </div>
  )}

  {historyCount > 0 && (
    <div class="tab-panel" data-panel="history" data-article={String(article.number)}>
      <DraftingHistory
        snapshots={draftingSnapshots}
        gaps={draftingGaps}
        stages={draftingStages}
        lang={lang}
        number={article.number}
        contentType="articles"
        currentText={article.paragraphs.map((p: any) => p.text).join('\n\n')}
        currentParaCount={article.paragraphs.length}
        currentTitle={article.title}
      />
    </div>
  )}

  {omnibusCount > 0 && (
    <div class="tab-panel" data-panel="omnibus" data-article={String(article.number)}>
      {omnibusAmendments.map((amend: any) => (
        <div class="recital-card" style="border-left-color: #d97706;">
          <div class="recital-card-header" style="color: #92400e;">
            Paragraph {amend.paragraph} — {amend.action}
            {amend.sub_provision && <span style="color: var(--gray-500);"> ({amend.sub_provision})</span>}
          </div>
          <p>{amend.summary}</p>
          <div class="relevance" style="color: #d97706;">COM(2025) 836 final — AI Omnibus Regulation</div>
          {lang === 'nl' && (
            <div style="margin-top: 6px; font-family: var(--sans); font-size: 11px; color: var(--gray-500); font-style: italic;">
              Bron: COM(2025) 836 — beschikbaar in het Engels
            </div>
          )}
        </div>
      ))}
    </div>
  )}

  <div class="tab-panel" data-panel="caselaw" data-article={String(article.number)}>
    <div class="caselaw-empty">
      <div class="caselaw-empty-icon">&#x2696;</div>
      No case law referencing Article {article.number} yet.
      <p>As courts and enforcement authorities produce decisions interpreting this provision, they will appear here.</p>
    </div>
  </div>

  {guidanceCount > 0 && (
    <div class="tab-panel" data-panel="guidance" data-article={String(article.number)}>
      {guidanceCards.map(({ doc, pinCites }) => (
        <GuidanceCard doc={doc} lang={lang} showPinCites={pinCites} />
      ))}
    </div>
  )}

  {referencedByEntries.length > 0 && (
    <div class="referenced-by">
      <div class="referenced-by-label">
        {lang === 'nl' ? 'Aangehaald door' : 'Referenced by'}
      </div>
      <ul class="referenced-by-list">
        {referencedByEntries.map((entry) => (
          <li>
            <a href={entry.href}>Article {entry.source_article}{entry.pin}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
