---
import '@/styles/global.css';
import TopBar from '@/components/TopBar.astro';
import type { Lang } from '@/types/aiact';

interface Props {
  title: string;
  activeChapter?: number;
  activeTopNav?: 'articles' | 'recitals' | 'annexes' | 'history' | 'guidance' | 'about';
  availableLangs?: readonly Lang[];
}

const { title, activeChapter, activeTopNav, availableLangs } = Astro.props;
const base = import.meta.env.BASE_URL;

const path = Astro.url.pathname;
const lang: Lang = path.startsWith('/nl/') ? 'nl' : 'en';
const noLang = path.replace(/^\/(en|nl)(\/|$)/, '/');

const topNav = activeTopNav
  ?? (noLang.startsWith('/recitals') ? 'recitals'
    : noLang.startsWith('/annexes') ? 'annexes'
    : noLang.startsWith('/history') ? 'history'
    : noLang.startsWith('/guidance') ? 'guidance'
    : noLang.startsWith('/about') ? 'about'
    : 'articles');

const siteOrigin = Astro.site ? Astro.site.origin : 'https://aiact.annotated.nl';
const canonicalUrl = `${siteOrigin}${path}`;
const enHref = `${siteOrigin}/en${noLang}`;
const nlHref = `${siteOrigin}/nl${noLang}`;

// Hreflang gap awareness — when the page exists in only one locale (drafting-
// history snapshots where the alt-language equivalent is absent per the
// catalogued asymmetry), the corresponding lang must be omitted from
// hreflang and x-default must point at the locale that actually exists.
// `availableLangs === undefined` means both locales render this page (the
// regulation-text default); both hreflang links are emitted as before.
const enAvailable = !availableLangs || availableLangs.includes('en');
const nlAvailable = !availableLangs || availableLangs.includes('nl');
const xDefaultHref = enAvailable ? enHref : nlHref;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — EU AI Act Annotated</title>
  <meta name="description" content="Annotated EU AI Act (Regulation 2024/1689) with recitals, drafting history, cross-references, and AI Omnibus amendments." />
  <link rel="canonical" href={canonicalUrl} />
  {enAvailable && <link rel="alternate" hreflang="en" href={enHref} />}
  {nlAvailable && <link rel="alternate" hreflang="nl" href={nlHref} />}
  <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
</head>
<body>

<TopBar lang={lang} currentPath={path} activeTopNav={topNav} availableLangs={availableLangs} />

<div class="layout">
<slot name="sidebar" />

<div class="main-wrapper">
  <main class="main">
    <slot />
  </main>

  <aside class="right-sidebar">
    <div class="rs-section">
      <h3>About This Resource</h3>
      <div class="rs-meta">Regulation (EU) 2024/1689</div>
      <div class="rs-meta">OJ L, 12.7.2024</div>
      <div class="rs-meta">Entry into force: 1 August 2024</div>
      <div class="rs-meta" style="margin-top: 6px; padding-top: 6px; border-top: 1px solid var(--gray-100);">Last updated: April 2026</div>
    </div>
    <div class="rs-section">
      <h3>Quick Links</h3>
      <a href="https://eur-lex.europa.eu/eli/reg/2024/1689/oj" target="_blank" rel="noopener">Full text on EUR-Lex</a>
      <a href="https://digital-strategy.ec.europa.eu/en/policies/european-approach-artificial-intelligence" target="_blank" rel="noopener">EU AI Office</a>
      <a href="https://ec.europa.eu/ai-act-service-desk" target="_blank" rel="noopener">AI Act Service Desk</a>
    </div>
    <div class="rs-section">
      <h3>Application Dates</h3>
      <div class="rs-meta"><strong style="color: var(--green-badge);">2 Feb 2025</strong> — Prohibited practices</div>
      <div class="rs-meta"><strong style="color: var(--green-badge);">2 Aug 2025</strong> — GPAI obligations</div>
      <div class="rs-meta"><strong style="color: var(--amber-badge);">2 Aug 2026</strong> — High-risk systems</div>
      <div class="rs-meta"><strong style="color: var(--gray-500);">2 Aug 2027</strong> — Annex I systems</div>
    </div>
    <div class="rs-section">
      <h3>Related Legislation</h3>
      <a href="#">GDPR (2016/679)</a>
      <a href="#">DSA (2022/2065)</a>
      <a href="#">DMA (2022/1925)</a>
      <a href="#">NIS2 (2022/2555)</a>
      <a href="#">DORA (2022/2554)</a>
      <a href="#">Product Liability Dir.</a>
    </div>
    <div class="rs-section">
      <h3>Contact</h3>
      <a href="https://abacuslegal.nl" target="_blank" rel="noopener">Abacus Legal</a>
      <a href="#">Suggest a correction</a>
    </div>
  </aside>
</div>

</div>

<script is:inline>
function switchTab(tabEl) {
  const tabBar = tabEl.parentElement;
  const articleId = tabBar.dataset.article;
  const tabName = tabEl.dataset.tab;
  if (tabEl.classList.contains('active')) {
    tabEl.classList.remove('active');
    document.querySelectorAll(`.tab-panel[data-article="${articleId}"]`).forEach(p => p.classList.remove('active'));
    return;
  }
  tabBar.querySelectorAll('.article-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll(`.tab-panel[data-article="${articleId}"]`).forEach(p => p.classList.remove('active'));
  tabEl.classList.add('active');
  const panel = document.querySelector(`.tab-panel[data-panel="${tabName}"][data-article="${articleId}"]`);
  if (panel) panel.classList.add('active');
}

// Deep-link: pre-select an article-block tab from a URL fragment.
// Recognised fragments: #recitals, #history, #omnibus, #caselaw, #guidance.
// Used by the guidance detail page's "Cited articles" sidebar so a click on
// an article anchor lands the reader on /{lang}/articles/.../article-N/ with
// the Guidance tab already open. Browser scrolls to an element whose id
// matches the hash; no element has these tab-name ids, so the page stays
// at top while the JS activates the tab.
const TAB_FRAGMENTS = ['recitals', 'history', 'omnibus', 'caselaw', 'guidance'];
function activateTabFromHash() {
  const hash = (location.hash || '').replace(/^#/, '');
  if (!TAB_FRAGMENTS.includes(hash)) return;
  const tab = document.querySelector('.article-tab[data-tab="' + hash + '"]');
  if (tab && !tab.classList.contains('active')) {
    switchTab(tab);
    tab.scrollIntoView({ behavior: 'auto', block: 'start' });
  }
}

document.addEventListener('DOMContentLoaded', () => {
  activateTabFromHash();
  window.addEventListener('hashchange', activateTabFromHash);

  document.querySelectorAll('.nav-chapter-header').forEach(header => {
    header.addEventListener('click', () => {
      header.parentElement.classList.toggle('open');
    });
  });
  document.querySelectorAll('.sidebar-expand-all').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.nav-chapter').forEach(c => c.classList.add('open'));
    });
  });
  document.querySelectorAll('.sidebar-collapse-all').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.nav-chapter').forEach(c => c.classList.remove('open'));
    });
  });
  document.querySelectorAll('.timeline-card').forEach(card => {
    card.addEventListener('click', () => card.classList.toggle('expanded'));
  });
  document.querySelectorAll('.timeline-compare-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const diffView = btn.nextElementSibling;
      if (diffView && diffView.classList.contains('diff-view')) {
        diffView.classList.toggle('active');
      }
    });
  });
});
</script>

</body>
</html>
