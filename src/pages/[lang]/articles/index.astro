---
/**
 * All-articles index — /en/articles/ and /nl/articles/.
 *
 * Step 4.3b: ports the legacy pages/articles/index.astro under [lang]/, with
 * loader-driven data and locale-prefixed links. AI Act layout preserved.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import {
  getArticles,
  getChapters,
  getIndexPagePaths,
} from '@/lib/loader';
import type { Lang } from '@/types/aiact';

export function getStaticPaths() {
  return getIndexPagePaths();
}

const lang = Astro.params.lang as Lang;

function titleCase(str: string) {
  return str
    .toLowerCase()
    .replace(/\b\w/g, (c) => c.toUpperCase())
    .replace(/\bAi\b/g, 'AI')
    .replace(/\bEu\b/g, 'EU')
    .replace(/\bGpai\b/g, 'GPAI');
}

const articles = getArticles(lang);
const chapters = getChapters(lang).map((ch) => ({
  ...ch,
  articles: articles.filter((a) => a.chapter === ch.number),
}));
---

<BaseLayout title="All Articles — EU AI Act Annotated">
  <Sidebar slot="sidebar" lang={lang} activeSection="articles" />

  <div class="chapter-bar">
    <h1>All Articles</h1>
  </div>

  <div style="padding: 8px 0 16px; font-family: var(--sans); font-size: 13px; color: var(--gray-500);">
    <a href={`/${lang}/`} style="color: var(--blue-accent); text-decoration: none;">Home</a>
    <span style="margin: 0 6px;">/</span>
    <span>Articles</span>
  </div>

  <div style="font-family: var(--sans); margin-bottom: 32px; padding: 16px 20px; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 6px; font-size: 13px; color: var(--gray-600);">
    {articles.length} articles across 13 chapters. Click an article to view it with its related recitals, drafting history, and Omnibus amendments (where applicable).
  </div>

  {chapters.map(ch => (
    <div style="margin-bottom: 28px;">
      <h2 style="font-family: var(--sans); font-size: 14px; font-weight: 700; color: var(--red-accent); text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid var(--gray-200);">
        <a href={`/${lang}/articles/chapter-${ch.number}/`} style="color: inherit; text-decoration: none;">Chapter {ch.roman} — {titleCase(ch.title)}</a>
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 8px; font-family: var(--sans);">
        {ch.articles.map(a => (
          <a href={`/${lang}/articles/chapter-${ch.number}/article-${a.number}/`} style="display: flex; gap: 8px; padding: 8px 12px; background: #fff; border: 1px solid var(--gray-200); border-radius: 4px; text-decoration: none; font-size: 13px;">
            <strong style="color: var(--red-accent); flex-shrink: 0;">Art. {a.number}</strong>
            <span style="color: var(--gray-700);">{a.title}</span>
          </a>
        ))}
      </div>
    </div>
  ))}
</BaseLayout>
