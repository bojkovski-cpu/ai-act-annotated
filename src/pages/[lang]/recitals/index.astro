---
/**
 * All-recitals index — /en/recitals/ and /nl/recitals/.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import { getRecitals, getIndexPagePaths } from '@/lib/loader';
import type { Lang } from '@/types/aiact';

export function getStaticPaths() {
  return getIndexPagePaths();
}

const lang = Astro.params.lang as Lang;
const recitals = getRecitals(lang);
---

<BaseLayout title="All Recitals — EU AI Act Annotated">
  <Sidebar slot="sidebar" lang={lang} activeSection="recitals" />

  <div class="chapter-bar">
    <h1>Recitals</h1>
  </div>

  <div style="padding: 8px 0 16px; font-family: var(--sans); font-size: 13px; color: var(--gray-500);">
    <a href={`/${lang}/`} style="color: var(--blue-accent); text-decoration: none;">Home</a>
    <span style="margin: 0 6px;">/</span>
    <span>Recitals</span>
  </div>

  <div style="font-family: var(--sans); margin-bottom: 32px; padding: 16px 20px; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 6px; font-size: 13px; color: var(--gray-600);">
    {recitals.length} recitals explain the rationale, context, and interpretive intent behind the regulation's articles.
    Recitals are not binding, but they guide interpretation — particularly useful when article wording is ambiguous.
  </div>

  <div style="font-family: var(--sans); display: flex; flex-direction: column; gap: 6px;">
    {recitals.map(r => {
      const preview = r.text.length > 200 ? r.text.substring(0, 200) + '…' : r.text;
      return (
        <a href={`/${lang}/recitals/recital-${r.number}/`} style="display: flex; gap: 14px; padding: 12px 16px; background: #fff; border: 1px solid var(--gray-200); border-left: 3px solid #2563eb; border-radius: 0 6px 6px 0; text-decoration: none; color: inherit;">
          <strong style="color: var(--blue-dark); flex-shrink: 0; min-width: 80px;">Recital {r.number}</strong>
          <span style="color: var(--gray-700); font-size: 13px; line-height: 1.5;">{preview}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>
