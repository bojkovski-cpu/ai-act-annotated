---
/** Legacy redirect — /annexes/annex-X/ → /en/annexes/annex-X/. */
import { getAnnexes } from '@/lib/loader';

export function getStaticPaths() {
  return getAnnexes('en').map((a) => ({
    params: { annex: `annex-${a.id.toLowerCase()}` },
    props: { target: `/en/annexes/annex-${a.id.toLowerCase()}/` },
  }));
}

const { target } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex,follow" />
  <title>Redirecting…</title>
</head>
<body><a href={target}>{target}</a></body>
</html>
