---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import data from '@data/ai_act_structured.json';

const annexes = data.annexes || [];
---

<BaseLayout title="Annexes — EU AI Act Annotated">
  <Sidebar slot="sidebar" activeSection="annexes" />

  <div class="chapter-bar">
    <h1>Annexes</h1>
  </div>

  <div style="padding: 8px 0 16px; font-family: var(--sans); font-size: 13px; color: var(--gray-500);">
    <a href="/" style="color: var(--blue-accent); text-decoration: none;">Home</a>
    <span style="margin: 0 6px;">/</span>
    <span>Annexes</span>
  </div>

  <div style="font-family: var(--sans); margin-bottom: 32px; padding: 16px 20px; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 6px; font-size: 13px; color: var(--gray-600);">
    {annexes.length} annexes to Regulation (EU) 2024/1689, including the list of Union harmonisation legislation (Annex I),
    the list of high-risk AI systems (Annex III), technical documentation requirements (Annex IV), and the conformity assessment procedures.
  </div>

  <div style="font-family: var(--sans); display: flex; flex-direction: column; gap: 8px;">
    {annexes.map(a => {
      const firstLine = a.text.split('\n').slice(1, 3).join(' ').substring(0, 200);
      return (
        <a href={`/annexes/annex-${a.id.toLowerCase()}/`} style="display: block; padding: 14px 18px; background: #fff; border: 1px solid var(--gray-200); border-left: 3px solid var(--red-accent); border-radius: 0 6px 6px 0; text-decoration: none; color: inherit;">
          <div style="font-weight: 700; color: var(--red-accent); font-size: 15px;">{a.title}</div>
          <div style="font-size: 13px; color: var(--gray-600); margin-top: 4px; line-height: 1.5;">{firstLine}…</div>
        </a>
      );
    })}
  </div>
</BaseLayout>
