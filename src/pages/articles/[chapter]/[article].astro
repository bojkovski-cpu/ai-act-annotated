---
/**
 * Legacy redirect — /articles/chapter-N/article-M/ → /en/articles/chapter-N/article-M/.
 * One stub per article. Deleted when the Caddy redirect block ships (3.4/4.7).
 */
import { getArticles } from '@/lib/loader';

export function getStaticPaths() {
  return getArticles('en').map((article) => ({
    params: {
      chapter: `chapter-${article.chapter}`,
      article: `article-${article.number}`,
    },
    props: {
      target: `/en/articles/chapter-${article.chapter}/article-${article.number}/`,
    },
  }));
}

const { target } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex,follow" />
  <title>Redirecting…</title>
</head>
<body><a href={target}>{target}</a></body>
</html>
