---
/**
 * Legacy redirect — /history/[version]/articles/[article]/ →
 * /en/history/[version]/articles/article-N/.
 *
 * Note: pre-4.4 this route used the article number directly (no "article-"
 * prefix); post-4.4 the slug is "article-N". The redirect maps from the
 * old shape to the new.
 */
import { getDraftingHistory } from '@/lib/loader';

export function getStaticPaths() {
  const blob = getDraftingHistory('en');
  // Use the union across both languages so all historical URLs resolve.
  const seen = new Set<string>();
  const out: Array<{ params: { version: string; article: string }; props: { target: string } }> = [];
  for (const lang of ['en', 'nl'] as const) {
    const b = lang === 'en' ? blob : getDraftingHistory('nl');
    for (const s of b.snapshots) {
      if (s.content_type !== 'articles') continue;
      const key = `${s.stage}|${s.number}`;
      if (seen.has(key)) continue;
      seen.add(key);
      out.push({
        params: { version: s.stage, article: s.number },
        props: { target: `/en/history/${s.stage}/articles/article-${s.number}/` },
      });
    }
  }
  return out;
}

const { target } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting…</title>
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex, follow" />
</head>
<body>
  <p>This page has moved. <a href={target}>Continue to the new location.</a></p>
</body>
</html>
