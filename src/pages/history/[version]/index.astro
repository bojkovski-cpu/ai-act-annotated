---
/**
 * Legacy redirect — /history/[version]/ → /en/history/[version]/.
 * See pages/history/index.astro for rationale.
 */
import { getDraftingStages } from '@/lib/loader';

export function getStaticPaths() {
  // Enumerate stages in EN (NL has the same set; either works).
  return getDraftingStages('en').map((s) => ({
    params: { version: s.id },
    props: { stageId: s.id },
  }));
}

const { stageId } = Astro.props;
const target = `/en/history/${stageId}/`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting…</title>
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex, follow" />
</head>
<body>
  <p>This page has moved. <a href={target}>Continue to the new location.</a></p>
</body>
</html>
