---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import history from '@data/drafting_history.json';
import data from '@data/ai_act_structured.json';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const [vKey, vData] of Object.entries(history.by_version as any)) {
    const recitals = (vData as any).recitals ?? {};
    for (const num of Object.keys(recitals)) {
      paths.push({
        params: { version: vKey, recital: String(num) },
        props: {
          versionKey: vKey,
          meta: (history.versions as any)[vKey],
          recital: recitals[num],
        },
      });
    }
  }
  return paths;
}

const { versionKey, meta, recital } = Astro.props;

const numStr = String(recital.number);
const otherVersionsWithThis = ((history.index as any).recitals[numStr] || [])
  .filter((v: string) => v !== versionKey);

const currentRecital = data.recitals.find(r => r.number === recital.number);
---

<BaseLayout title={`Recital ${recital.number} — ${meta.label}`}>
  <Sidebar slot="sidebar" activeSection="history" />

  <div class="chapter-bar" style="background: #d97706;">
    <h1>Recital {recital.number}</h1>
  </div>

  <div style="padding: 8px 0 16px; font-family: var(--sans); font-size: 13px; color: var(--gray-500);">
    <a href="/" style="color: var(--blue-accent); text-decoration: none;">Home</a>
    <span style="margin: 0 6px;">/</span>
    <a href="/history/" style="color: var(--blue-accent); text-decoration: none;">Drafting History</a>
    <span style="margin: 0 6px;">/</span>
    <a href={`/history/${versionKey}/`} style="color: var(--blue-accent); text-decoration: none;">{meta.label}</a>
    <span style="margin: 0 6px;">/</span>
    <span>Recital {recital.number}</span>
  </div>

  <div style="font-family: var(--sans); margin-bottom: 20px; padding: 12px 16px; background: #fffbeb; border: 1px solid #fbbf24; border-left: 3px solid #d97706; border-radius: 0 6px 6px 0; font-size: 13px; color: #92400e;">
    <strong>{meta.label}</strong> · {meta.date} · <span style="font-family: var(--serif); font-style: italic;">{meta.source}</span>
  </div>

  <div class="article-block">
    <div class="article-body">
      <pre style="white-space: pre-wrap; font-family: var(--serif); font-size: 15px; line-height: 1.7; color: var(--gray-800); margin: 0;">{recital.body}</pre>
    </div>
  </div>

  <div style="margin-top: 32px; padding: 16px 20px; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 6px; font-family: var(--sans);">
    <div style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.4px; font-weight: 700; color: var(--gray-500); margin-bottom: 10px;">Compare versions</div>
    {currentRecital && (
      <a href={`/recitals/recital-${currentRecital.number}/`} style="display: block; padding: 8px 0; color: var(--blue-dark); text-decoration: none; font-size: 13px;">
        &rarr; Final adopted text — Recital {currentRecital.number}
      </a>
    )}
    {otherVersionsWithThis.map((v: string) => {
      const vMeta = (history.versions as any)[v];
      return (
        <a href={`/history/${v}/recitals/${recital.number}/`} style="display: block; padding: 8px 0; color: #d97706; text-decoration: none; font-size: 13px;">
          &rarr; {vMeta.label} ({vMeta.date})
        </a>
      );
    })}
  </div>
</BaseLayout>
