---
/**
 * Legacy redirect — /history/[version]/recitals/[recital]/ →
 * /en/history/[version]/recitals/recital-N/.
 */
import { getDraftingHistory } from '@/lib/loader';

export function getStaticPaths() {
  const seen = new Set<string>();
  const out: Array<{ params: { version: string; recital: string }; props: { target: string } }> = [];
  for (const lang of ['en', 'nl'] as const) {
    const b = getDraftingHistory(lang);
    for (const s of b.snapshots) {
      if (s.content_type !== 'recitals') continue;
      const key = `${s.stage}|${s.number}`;
      if (seen.has(key)) continue;
      seen.add(key);
      out.push({
        params: { version: s.stage, recital: s.number },
        props: { target: `/en/history/${s.stage}/recitals/recital-${s.number}/` },
      });
    }
  }
  return out;
}

const { target } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting…</title>
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex, follow" />
</head>
<body>
  <p>This page has moved. <a href={target}>Continue to the new location.</a></p>
</body>
</html>
