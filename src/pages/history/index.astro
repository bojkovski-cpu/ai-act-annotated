---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import history from '@data/drafting_history.json';

const versions = Object.entries(history.versions) as [string, {label: string; date: string; source: string}][];
const stats = history.stats as Record<string, {articles: number; recitals: number}>;
---

<BaseLayout title="Drafting History — EU AI Act Annotated">
  <Sidebar slot="sidebar" activeSection="history" />

  <div class="chapter-bar">
    <h1>Drafting History</h1>
  </div>

  <div style="padding: 8px 0 16px; font-family: var(--sans); font-size: 13px; color: var(--gray-500);">
    <a href="/" style="color: var(--blue-accent); text-decoration: none;">Home</a>
    <span style="margin: 0 6px;">/</span>
    <span>Drafting History</span>
  </div>

  <div style="font-family: var(--sans); margin-bottom: 32px; padding: 20px; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 6px; font-size: 14px; color: var(--gray-700); line-height: 1.65;">
    <p style="margin-bottom: 12px;">The AI Act went through three publicly-documented stages from proposal to adoption. Comparing the versions reveals where contested provisions were strengthened, softened, or reframed.</p>
    <p style="margin-bottom: 0; font-size: 13px; color: var(--gray-600);"><em>Parliament's 2023 mandate materially reshaped the original proposal; the trilogue produced the final text in December 2023, formally adopted July 2024.</em></p>
  </div>

  <div style="font-family: var(--sans); display: flex; flex-direction: column; gap: 14px;">
    {versions.map(([key, meta]) => {
      const s = stats[key] || { articles: 0, recitals: 0 };
      return (
        <a href={`/history/${key}/`} style="display: block; padding: 18px 22px; background: #fff; border: 1px solid var(--gray-200); border-left: 4px solid #d97706; border-radius: 0 6px 6px 0; text-decoration: none; color: inherit;">
          <div style="display: flex; justify-content: space-between; align-items: baseline;">
            <div>
              <span style="font-weight: 700; color: #d97706; font-size: 15px;">{meta.label}</span>
              <span style="color: var(--gray-500); font-size: 13px; margin-left: 10px;">{meta.date}</span>
            </div>
            <span style="font-size: 12px; color: var(--gray-500); font-family: var(--serif); font-style: italic;">{meta.source}</span>
          </div>
          <div style="font-size: 12px; color: var(--gray-500); margin-top: 6px;">
            {s.articles} article{s.articles !== 1 ? 's' : ''} · {s.recitals} recital{s.recitals !== 1 ? 's' : ''} preserved
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
