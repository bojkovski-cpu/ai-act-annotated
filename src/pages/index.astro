---
/**
 * Root stub — meta-refresh redirect to /en/.
 *
 * Step 4.3b, Decision 1+2 from the i18n decision note: every content page
 * lives under /en/ or /nl/. The bare root has no content and serves as a
 * redirect to the default English locale.
 *
 * SEO posture:
 *   - canonical points at /en/ (the alias of record)
 *   - hreflang alternates declare both /en/ and /nl/, plus x-default → /en/
 *   - <html lang="en"> hardcoded (no browser-language negotiation)
 *   - <meta name="robots" content="noindex,follow"> — search engines should
 *     index /en/ and /nl/ directly, not the stub
 *
 * GDPR pattern source: gdpr-site-snapshot/src/pages/index.astro. Visual
 * content (brand markup) follows the AI Act house style per the house
 * principle.
 */
const site = (Astro.site ?? new URL('https://aiact.annotated.nl')).origin;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EU AI Act — Annotated Edition</title>
  <meta name="description" content="Annotated EU AI Act (Regulation 2024/1689) with recitals, drafting history, cross-references, and AI Omnibus amendments." />
  <meta name="robots" content="noindex,follow" />
  <link rel="canonical" href={`${site}/en/`} />
  <link rel="alternate" hreflang="en" href={`${site}/en/`} />
  <link rel="alternate" hreflang="nl" href={`${site}/nl/`} />
  <link rel="alternate" hreflang="x-default" href={`${site}/en/`} />
  <meta http-equiv="refresh" content="0; url=/en/" />
</head>
<body style="font-family: system-ui, sans-serif; padding: 32px; color: #333;">
  <p>
    Redirecting to the English edition…
    If you are not redirected, follow this link:
    <a href="/en/">EU AI Act — Annotated Edition (English)</a>.
  </p>
  <p>
    Voor de Nederlandse versie: <a href="/nl/">Verordening (EU) 2024/1689 — Geannoteerde Editie (Nederlands)</a>.
  </p>
</body>
</html>
